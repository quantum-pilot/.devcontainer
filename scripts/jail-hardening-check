#!/usr/bin/env bash
set -euo pipefail

fail=0

check_fail() {
  printf 'FAIL: %s\n' "$1"
  fail=1
}

check_ok() {
  printf 'OK: %s\n' "$1"
}

if command -v sudo >/dev/null 2>&1 && sudo -n true >/dev/null 2>&1; then
  check_fail "passwordless sudo is available"
else
  check_ok "passwordless sudo unavailable"
fi

if id -nG | tr ' ' '\n' | grep -qx root; then
  check_fail "user is in root group"
else
  check_ok "user is not in root group"
fi

if [[ -S /var/run/docker.sock || -S /run/docker.sock ]]; then
  check_fail "Docker socket is mounted"
else
  check_ok "Docker socket absent"
fi

if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
  check_fail "SSH_AUTH_SOCK is present"
else
  check_ok "SSH agent socket absent"
fi

if [[ -r /jail-ssh-broker-token && -n "${JAIL_SSH_BROKER_HOST:-}" && -n "${JAIL_SSH_BROKER_PORT:-}" ]]; then
  check_ok "SSH broker configuration is mounted"
else
  check_fail "SSH broker configuration is missing"
fi

if [[ "$(command -v ssh)" == "/usr/local/bin/ssh" && "$(readlink -f /usr/bin/ssh 2>/dev/null || true)" == "/usr/local/bin/ssh" ]]; then
  check_ok "SSH resolves to the broker shim"
else
  check_fail "SSH does not resolve to the broker shim"
fi

if [[ ! -x /usr/bin/ssh.real ]]; then
  check_ok "raw OpenSSH client is not directly executable"
else
  check_fail "raw OpenSSH client remains directly executable"
fi

if find "$HOME/.ssh" -maxdepth 1 -type f \( -name 'id_*' ! -name '*.pub' \) 2>/dev/null | grep -q .; then
  check_fail "SSH private key exists in home"
else
  check_ok "SSH private keys absent from home"
fi

if [[ -d "$HOME/.claude" && -d "$HOME/.codex" && -d "$HOME/.agents" ]]; then
  check_ok "agent state directories are available inside the jail"
else
  check_fail "agent state directories are missing"
fi

if [[ -L "$HOME/.claude.json" && -d "$HOME/.claude-home" && -w "$HOME/.claude-home" ]]; then
  check_ok "Claude home-level state is persisted through a writable volume"
else
  check_fail "Claude home-level state is not persisted"
fi

if [[ -e /policy/approvals.json || -e "$HOME/.devcontainer-jail/policy/approvals.json" ]]; then
  check_fail "host approval policy is visible in the worker"
else
  check_ok "host approval policy is not mounted in the worker"
fi

if awk '/NoNewPrivs:/ { exit ($2 == 1 ? 0 : 1) }' /proc/self/status; then
  check_ok "no_new_privs is enabled"
else
  check_fail "no_new_privs is not enabled"
fi

if awk '/Seccomp:/ { exit ($2 == 0 ? 1 : 0) }' /proc/self/status; then
  check_ok "seccomp is enabled"
else
  check_fail "seccomp is disabled"
fi

cap_eff=$(awk '/CapEff:/ { print $2 }' /proc/self/status)
if [[ "$cap_eff" == "0000000000000000" ]]; then
  check_ok "effective capabilities are empty"
else
  check_fail "effective capabilities are not empty: $cap_eff"
fi

if [[ "${HTTP_PROXY:-}" == "http://proxy:8080" && "${HTTPS_PROXY:-}" == "http://proxy:8080" ]]; then
  check_ok "proxy environment points at proxy"
else
  check_fail "proxy environment is not configured for proxy"
fi

pnpm_global_bin="${PNPM_HOME:-$HOME/.local/share/pnpm}/bin"
case ":$PATH:" in
  *":$pnpm_global_bin:"*|*":${PNPM_HOME:-$HOME/.local/share/pnpm}:"*)
    check_ok "pnpm global bin location is on PATH"
    ;;
  *)
    check_fail "pnpm global bin location is missing from PATH: ${PNPM_HOME:-$HOME/.local/share/pnpm}"
    ;;
esac

npm_global_bin="${NPM_CONFIG_PREFIX:-$HOME/.local}/bin"
case ":$PATH:" in
  *":$npm_global_bin:"*)
    check_ok "npm global bin directory is on PATH"
    ;;
  *)
    check_fail "npm global bin directory is missing from PATH: $npm_global_bin"
    ;;
esac

if [[ "${NPM_CONFIG_PREFIX:-}" == "$HOME/.local" && -w "${NPM_CONFIG_PREFIX:-}" ]]; then
  check_ok "npm global prefix is writable"
else
  check_fail "npm global prefix is not writable: ${NPM_CONFIG_PREFIX:-unset}"
fi

if command -v uv >/dev/null 2>&1 && command -v uvx >/dev/null 2>&1; then
  check_ok "uv and uvx are available"
else
  check_fail "uv or uvx is missing"
fi

if [[ "${UV_CACHE_DIR:-}" == "$HOME/.local/cache/uv" && -w "${UV_CACHE_DIR:-}" ]]; then
  check_ok "uv cache directory is writable under executable user-local storage"
else
  check_fail "uv cache directory is not configured for executable user-local storage: ${UV_CACHE_DIR:-unset}"
fi

if [[ "${UV_PYTHON_INSTALL_DIR:-}" == "$HOME/.local/share/uv/python" && -w "${UV_PYTHON_INSTALL_DIR:-}" ]]; then
  check_ok "uv-managed Python install directory is writable"
else
  check_fail "uv-managed Python install directory is not writable: ${UV_PYTHON_INSTALL_DIR:-unset}"
fi

if [[ "${UV_PYTHON_BIN_DIR:-}" == "$HOME/.local/bin" && "${UV_TOOL_BIN_DIR:-}" == "$HOME/.local/bin" ]]; then
  check_ok "uv executable bin directories point at user-local bin"
else
  check_fail "uv executable bin directories are not configured for user-local bin"
fi

if [[ "${XDG_CONFIG_HOME:-}" == "$HOME/.local/config" && -w "${XDG_CONFIG_HOME:-}" ]]; then
  check_ok "XDG config directory is writable"
else
  check_fail "XDG config directory is not writable: ${XDG_CONFIG_HOME:-unset}"
fi

if [[ "${GNUPGHOME:-}" == "$HOME/.local/share/gnupg" && -d "${GNUPGHOME:-}" && -w "${GNUPGHOME:-}" && "$(stat -c %a "${GNUPGHOME:-}" 2>/dev/null)" == "700" ]]; then
  check_ok "GnuPG home is writable"
else
  check_fail "GnuPG home is not private and writable: ${GNUPGHOME:-unset}"
fi

if command -v mise >/dev/null 2>&1; then
  check_ok "mise is available"
else
  check_fail "mise is missing"
fi

if [[ "${MISE_DATA_DIR:-}" == "$HOME/.local/share/mise" && -w "${MISE_DATA_DIR:-}" ]]; then
  check_ok "mise data directory is writable under executable user-local storage"
else
  check_fail "mise data directory is not writable: ${MISE_DATA_DIR:-unset}"
fi

case ":$PATH:" in
  *":${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims:"*)
    check_ok "mise shims are on PATH"
    ;;
  *)
    check_fail "mise shims are missing from PATH"
    ;;
esac

if [[ "${MISE_CONFIG_DIR:-}" == "$HOME/.local/share/mise/config" && -w "${MISE_CONFIG_DIR:-}" ]]; then
  check_ok "mise config directory is writable for per-user trust/config"
else
  check_fail "mise config directory is not writable: ${MISE_CONFIG_DIR:-unset}"
fi

if [[ -d "${TMPDIR:-$HOME/.local/tmp}" && -w "${TMPDIR:-$HOME/.local/tmp}" ]]; then
  check_ok "TMPDIR is writable for installers"
else
  check_fail "TMPDIR is not writable for installers"
fi

exec_probe="$HOME/.local/.exec-probe-$$"
if printf '#!/bin/sh\nexit 0\n' > "$exec_probe" && chmod 700 "$exec_probe" && "$exec_probe"; then
  check_ok "$HOME/.local allows user-installed executables"
else
  check_fail "$HOME/.local is not executable; package-manager installed tools will fail"
fi
rm -f "$exec_probe"

if find / -xdev -perm /6000 -type f 2>/dev/null | grep -q .; then
  check_fail "setuid/setgid files remain in root filesystem"
else
  check_ok "no setuid/setgid files found in root filesystem"
fi

exit "$fail"
