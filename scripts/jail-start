#!/usr/bin/env bash
set -euo pipefail

mkdir -p \
  "$HOME/.cache" \
  "$HOME/.npm" \
  "$HOME/.local/bin" \
  "$HOME/.local/cache/zsh" \
  "$HOME/.local/config" \
  "$HOME/.local/config/git" \
  "$HOME/.local/config/shell" \
  "$HOME/.local/cache/mise" \
  "$HOME/.local/cache/uv" \
  "$HOME/.local/state/mise" \
  "$HOME/.local/share/gnupg" \
  "$HOME/.local/share/mise" \
  "$HOME/.local/share/mise/config" \
  "$HOME/.local/share/pnpm/bin" \
  "$HOME/.local/share/uv/python" \
  "$HOME/.local/share/uv/tools" \
  "$HOME/.local/share/headroom"

chmod 700 "$HOME/.local/share/gnupg"

headroom_session="${JAIL_HEADROOM_TMUX_SESSION:-headroom}"

if command -v tmux >/dev/null 2>&1 && command -v headroom >/dev/null 2>&1; then
  if ! tmux has-session -t "=${headroom_session}" 2>/dev/null; then
    tmux new-session -d -s "$headroom_session" -n proxy /usr/local/bin/headroom-proxy
  fi
  tmux set-option -g mouse on 2>/dev/null || true
fi

exec sleep infinity
