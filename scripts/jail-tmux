#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
import shlex
import subprocess
import sys
import uuid
from pathlib import Path


DEFAULT_LAYOUT = Path(os.environ.get("JAIL_TMUX_LAYOUT", "/workspace/.devcontainer/.jail/tmux-layout.json"))
SEP = "\x1f"


def tmux(args, check=True):
    proc = subprocess.run(
        ["tmux", *args],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if check and proc.returncode:
        raise SystemExit(proc.stderr.strip() or f"tmux {' '.join(args)} failed")
    return proc.stdout


def tmux_ok(args):
    return subprocess.run(["tmux", *args], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def current_session():
    if not os.environ.get("TMUX"):
        return ""
    return tmux(["display-message", "-p", "#{session_name}"], check=False).strip()


def managed_sessions():
    raw = os.environ.get("JAIL_MANAGED_TMUX_SESSIONS", os.environ.get("JAIL_HEADROOM_TMUX_SESSION", "headroom"))
    return {item.strip() for item in raw.split(",") if item.strip()}


def rows(args, fields):
    fmt = SEP.join(f"#{{{field}}}" for field in fields)
    output = tmux([*args, "-F", fmt])
    return [dict(zip(fields, line.split(SEP))) for line in output.splitlines()]


def read_cmdline(pid):
    try:
        raw = Path(f"/proc/{pid}/cmdline").read_bytes()
    except OSError:
        return []
    return [part.decode("utf-8", "replace") for part in raw.split(b"\0") if part]


def read_comm(pid):
    try:
        return Path(f"/proc/{pid}/comm").read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def proc_table():
    table = {}
    for entry in Path("/proc").iterdir():
        if not entry.name.isdigit():
            continue
        try:
            stat = (entry / "stat").read_text(encoding="utf-8")
        except OSError:
            continue
        close = stat.rfind(")")
        if close == -1:
            continue
        fields = stat[close + 2 :].split()
        if len(fields) < 20:
            continue
        pid = int(entry.name)
        table[pid] = {
            "pid": pid,
            "ppid": int(fields[1]),
            "starttime": int(fields[19]),
            "comm": read_comm(pid),
            "argv": read_cmdline(pid),
        }
    return table


def process_descendants(root_pid, table):
    children = {}
    for proc in table.values():
        children.setdefault(proc["ppid"], []).append(proc)
    found = []
    stack = list(children.get(root_pid, []))
    while stack:
        proc = stack.pop(0)
        found.append(proc)
        stack.extend(children.get(proc["pid"], []))
    return found


def command_name_for_script(script):
    script_path = Path(script)
    for directory in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(directory) / script_path.name
        try:
            if candidate.exists() and candidate.resolve() == script_path.resolve():
                return candidate.name
        except OSError:
            continue
    return ""


def compact_argv(argv):
    if len(argv) >= 2 and Path(argv[1]).exists():
        resolved = command_name_for_script(argv[1])
        if resolved:
            return [resolved, *argv[2:]]
    return argv


def process_snapshot(root_pid, table, ignored_pids):
    processes = []
    for proc in sorted(process_descendants(root_pid, table), key=lambda item: (item["starttime"], item["pid"])):
        if proc["pid"] in ignored_pids or not proc["argv"]:
            continue
        compact = compact_argv(proc["argv"])
        processes.append({
            "pid": proc["pid"],
            "ppid": proc["ppid"],
            "comm": proc["comm"],
            "argv": proc["argv"],
            "cmdline": shlex.join(compact),
        })
    detected = processes[-1]["cmdline"] if processes else ""
    return processes, detected


def snapshot(args):
    sessions = []
    table = proc_table()
    ignored_pids = {os.getpid(), os.getppid()}
    ignored_pids.update(proc["pid"] for proc in process_descendants(os.getpid(), table))
    active_session = current_session()
    excluded_sessions = set() if args.include_managed else managed_sessions()

    for session_row in rows(["list-sessions"], ["session_name", "session_created_string", "session_attached"]):
        session_name = session_row["session_name"]
        if session_name in excluded_sessions:
            continue
        windows = []
        for window_row in rows(
            ["list-windows", "-t", session_name],
            ["window_index", "window_name", "window_active", "window_layout"],
        ):
            window_target = f"{session_name}:{window_row['window_index']}"
            panes = []
            for pane_row in rows(
                ["list-panes", "-t", window_target],
                [
                    "pane_index",
                    "pane_id",
                    "pane_active",
                    "pane_current_path",
                    "pane_current_command",
                    "pane_title",
                    "pane_width",
                    "pane_height",
                    "pane_pid",
                ],
            ):
                pane_pid = int(pane_row["pane_pid"] or 0)
                process_tree, detected_command = process_snapshot(pane_pid, table, ignored_pids)
                panes.append({
                    "index": int(pane_row["pane_index"]),
                    "id": pane_row["pane_id"],
                    "pid": pane_pid,
                    "active": pane_row["pane_active"] == "1",
                    "cwd": pane_row["pane_current_path"],
                    "title": pane_row["pane_title"],
                    "tmux_process": pane_row["pane_current_command"],
                    "processes": process_tree,
                    "size": {
                        "width": int(pane_row["pane_width"] or 0),
                        "height": int(pane_row["pane_height"] or 0),
                    },
                    "command": "" if args.no_commands else detected_command,
                })
            windows.append({
                "index": int(window_row["window_index"]),
                "name": window_row["window_name"],
                "active": window_row["window_active"] == "1",
                "layout": window_row["window_layout"],
                "panes": panes,
            })
        sessions.append({
            "name": session_name,
            "created": session_row["session_created_string"],
            "attached": session_row["session_attached"] == "1",
            "current": session_name == active_session,
            "windows": windows,
        })

    data = {
        "version": 1,
        "captured_at": dt.datetime.now(dt.timezone.utc).isoformat(),
        "current_session": "" if active_session in excluded_sessions else active_session,
        "note": "Edit pane.command before restore when the detected command is not what should be restarted.",
        "sessions": sessions,
    }
    args.path.parent.mkdir(parents=True, exist_ok=True)
    args.path.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")
    print(f"wrote {args.path}")
    print(f"captured {len(sessions)} session(s)")


def pane_cwd(window, pane_index):
    for pane in window.get("panes") or []:
        if int(pane.get("index", -1)) == pane_index:
            return pane.get("cwd") or str(Path.home())
    return str(Path.home())


def create_session(session_name, first_window):
    tmux(["new-session", "-d", "-s", session_name, "-n", first_window.get("name") or "0", "-c", pane_cwd(first_window, 0)])


def restore_session(session, target_name):
    windows = sorted(session.get("windows") or [], key=lambda item: int(item.get("index", 0)))
    if not windows:
        return
    create_session(target_name, windows[0])
    for offset, window in enumerate(windows):
        window_index = int(window.get("index", offset))
        target_window = f"{target_name}:{window_index}"
        panes = sorted(window.get("panes") or [], key=lambda item: int(item.get("index", 0)))
        if offset == 0:
            tmux(["move-window", "-s", f"{target_name}:0", "-t", target_window], check=False)
            tmux(["rename-window", "-t", target_window, window.get("name") or str(window_index)])
        else:
            tmux(["new-window", "-t", target_window, "-n", window.get("name") or str(window_index), "-c", pane_cwd(window, 0)])

        for pane in panes[1:]:
            tmux(["split-window", "-t", target_window, "-c", pane.get("cwd") or str(Path.home())])

        if window.get("layout"):
            tmux(["select-layout", "-t", target_window, window["layout"]], check=False)

        for pane in panes:
            pane_target = f"{target_window}.{int(pane.get('index', 0))}"
            if pane.get("cwd"):
                tmux(["send-keys", "-t", pane_target, f"cd {shlex.quote(pane['cwd'])}", "C-m"])
            if pane.get("title"):
                tmux(["select-pane", "-t", pane_target, "-T", pane["title"]], check=False)
            if pane.get("command"):
                tmux(["send-keys", "-t", pane_target, pane["command"], "C-m"])

        active_pane = next((pane for pane in panes if pane.get("active")), None)
        if active_pane:
            tmux(["select-pane", "-t", f"{target_window}.{int(active_pane.get('index', 0))}"], check=False)

    active_window = next((window for window in windows if window.get("active")), None)
    if active_window:
        tmux(["select-window", "-t", f"{target_name}:{int(active_window.get('index', 0))}"], check=False)


def restore(args):
    if not args.path.exists():
        raise SystemExit(f"snapshot not found: {args.path}")
    data = json.loads(args.path.read_text(encoding="utf-8"))
    active_now = current_session()
    restored_current = data.get("current_session") or ""
    temp_names = {}
    old_current_name = ""

    excluded_sessions = set() if args.include_managed else managed_sessions()
    sessions = [
        session
        for session in data.get("sessions", [])
        if session.get("name") not in excluded_sessions
    ]

    for session in sessions:
        original_name = session["name"]
        target_name = f"{args.prefix}{original_name}" if args.prefix else original_name
        restore_name = target_name
        is_current_target = bool(active_now and active_now == target_name)
        if is_current_target:
            restore_name = f"__jail_restore_{target_name}_{uuid.uuid4().hex[:8]}"
            old_current_name = f"__jail_old_{target_name}_{uuid.uuid4().hex[:8]}"
            temp_names[restore_name] = target_name
        elif tmux_ok(["has-session", "-t", f"={target_name}"]):
            tmux(["kill-session", "-t", f"={target_name}"])

        restore_session(session, restore_name)

    for temp_name, target_name in temp_names.items():
        if tmux_ok(["has-session", "-t", f"={target_name}"]):
            tmux(["rename-session", "-t", f"={target_name}", old_current_name])
        tmux(["rename-session", "-t", f"={temp_name}", target_name])
        if active_now == target_name:
            tmux(["switch-client", "-t", f"={target_name}"], check=False)
            tmux(["kill-session", "-t", f"={old_current_name}"], check=False)

    if restored_current:
        target_current = f"{args.prefix}{restored_current}" if args.prefix else restored_current
        tmux(["switch-client", "-t", f"={target_current}"], check=False)

    print(f"restored {len(sessions)} session(s)")


def main():
    parser = argparse.ArgumentParser(description="Snapshot and restore tmux sessions for the jail devcontainer.")
    subparsers = parser.add_subparsers(dest="command", required=True)

    snap = subparsers.add_parser("snapshot", help="snapshot all tmux sessions")
    snap.add_argument("--path", type=Path, default=DEFAULT_LAYOUT)
    snap.add_argument("--no-commands", action="store_true", help="leave pane.command empty instead of using detected argv")
    snap.add_argument("--include-managed", action="store_true", help=argparse.SUPPRESS)
    snap.set_defaults(func=snapshot)

    restore_parser = subparsers.add_parser("restore", help="restore all tmux sessions from the snapshot")
    restore_parser.add_argument("--path", type=Path, default=DEFAULT_LAYOUT)
    restore_parser.add_argument("--prefix", default="", help=argparse.SUPPRESS)
    restore_parser.add_argument("--include-managed", action="store_true", help=argparse.SUPPRESS)
    restore_parser.set_defaults(func=restore)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
