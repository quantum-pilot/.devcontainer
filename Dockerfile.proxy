FROM python:3.12-alpine

COPY scripts/egress-proxy.py /usr/local/bin/egress-proxy
COPY scripts/tcp-forwarder.py /usr/local/bin/tcp-forwarder
COPY scripts/proxy-entrypoint /usr/local/bin/proxy-entrypoint
RUN chmod 0755 /usr/local/bin/egress-proxy /usr/local/bin/tcp-forwarder /usr/local/bin/proxy-entrypoint

EXPOSE 8080
EXPOSE 8822
ENTRYPOINT ["/usr/local/bin/proxy-entrypoint"]
