{
  "name": "Vibe Coding Hardened Jail",
  "dockerComposeFile": "docker-compose.yml",
  "service": "worker",
  "runServices": ["egress-proxy", "ssh-broker-proxy"],
  "workspaceFolder": "/workspace",
  "remoteUser": "node",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "initializeCommand": ".devcontainer/host/devcontainer-config && .devcontainer/host/jail-init && .devcontainer/host-start-chrome.sh",
  "containerEnv": {
    "HTTP_PROXY": "http://egress-proxy:8080",
    "HTTPS_PROXY": "http://egress-proxy:8080",
    "ALL_PROXY": "http://egress-proxy:8080",
    "NO_PROXY": "localhost,127.0.0.1,::1,egress-proxy,ssh-broker-proxy"
  },
  "customizations": {
    "jail": {
      "buildArgs": {
        "ENABLE_PYTHON": "true",
        "PYTHON_VERSION": "3.12",
        "ENABLE_GO": "true",
        "GO_VERSION": "1.26.4",
        "GO_ARCH": "amd64",
        "ENABLE_RUST": "true",
        "RUST_VERSION": "stable",
        "ENABLE_PLAYWRIGHT": "true"
      },
      "hostChrome": {
        "enabled": true,
        "port": 9222,
        "bind": "127.0.0.1",
        "profile": "$HOME/.chrome-remote-test"
      }
    },
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "postCreateCommand": "jail-hardening-check"
}
