{
  "name": "Vibe Coding Hardened Jail",
  "dockerComposeFile": "docker-compose.yml",
  "service": "worker",
  "runServices": ["egress-proxy"],
  "workspaceFolder": "/workspace",
  "remoteUser": "node",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "initializeCommand": ".devcontainer/host/jail-init && .devcontainer/host-start-chrome.sh || true",
  "containerEnv": {
    "HTTP_PROXY": "http://egress-proxy:8080",
    "HTTPS_PROXY": "http://egress-proxy:8080",
    "ALL_PROXY": "http://egress-proxy:8080",
    "NO_PROXY": "localhost,127.0.0.1,::1,egress-proxy"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "postCreateCommand": "jail-hardening-check"
}
