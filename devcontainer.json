{
  "name": "Vibe Coding Hardened Jail",
  "dockerComposeFile": "docker-compose.yml",
  "service": "worker",
  "runServices": ["proxy"],
  "workspaceFolder": "/workspace",
  "remoteUser": "node",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "initializeCommand": ".devcontainer/host/jail-init && .devcontainer/host/jail-render-env && .devcontainer/host-start-chrome.sh",
  "containerEnv": {
    "HTTP_PROXY": "http://proxy:8080",
    "HTTPS_PROXY": "http://proxy:8080",
    "ALL_PROXY": "http://proxy:8080",
    "NO_PROXY": "localhost,127.0.0.1,::1,proxy"
  },
  "customizations": {
    "jail": {
      "hostChrome": {
        "enabled": true,
        "port": 9222,
        "bind": "127.0.0.1",
        "profile": "$HOME/.chrome-remote-test"
      },
      "bridgePorts": [5432, 5435]
    },
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "postCreateCommand": "jail-hardening-check"
}
