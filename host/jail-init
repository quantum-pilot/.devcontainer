#!/usr/bin/env bash
set -euo pipefail

base="${DEVCONTAINER_JAIL_HOME:-$HOME/.devcontainer-jail}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
default_hosts_file="${JAIL_DEFAULT_EGRESS_HOSTS_FILE:-$script_dir/default-egress-hosts.txt}"
mkdir -p "$base/policy" "$base/policy/ssh-leases" "$base/state" "$base/requests"
token_file="$base/state/ssh-broker-token"

if [[ ! -f "$token_file" ]]; then
  umask 077
  python3 - <<'PY' > "$token_file"
import secrets
print(secrets.token_urlsafe(48))
PY
fi

if [[ ! -f "$base/policy/approvals.json" ]]; then
  cat > "$base/policy/approvals.json" <<'JSON'
{
  "blocks": [],
  "rules": []
}
JSON
fi

if [[ ! -f "$base/policy/ssh-allowlist.json" ]]; then
  cat > "$base/policy/ssh-allowlist.json" <<'JSON'
{
  "blocks": {},
  "aliases": {}
}
JSON
fi

if [[ -f "$default_hosts_file" ]]; then
  APPROVALS_FILE="$base/policy/approvals.json" DEFAULT_EGRESS_HOSTS_FILE="$default_hosts_file" python3 - <<'PY'
import datetime as dt
import json
import os
from pathlib import Path

path = Path(os.environ["APPROVALS_FILE"])
hosts_path = Path(os.environ["DEFAULT_EGRESS_HOSTS_FILE"])
try:
    data = json.loads(path.read_text(encoding="utf-8"))
except (FileNotFoundError, json.JSONDecodeError):
    data = {"rules": []}

rules = data.setdefault("rules", [])
data.setdefault("blocks", [])
now = dt.datetime.now(dt.timezone.utc).isoformat()
defaults = []
for line in hosts_path.read_text(encoding="utf-8").splitlines():
    parts = line.split("#", 1)[0].split()
    if not parts:
        continue
    target = parts[0]
    host, sep, port = target.rpartition(":")
    if not sep or not port.isdigit():
        host, port = target, 443
    protocols = parts[1:] or ["connect"]
    defaults.append((host, int(port), protocols))

def same_rule(rule, host, port, protocols):
    return (
        isinstance(rule, dict)
        and rule.get("host") == host
        and int(rule.get("port") or 443) == port
        and set(rule.get("protocols") or []) == set(protocols)
    )

for host, port, protocols in defaults:
    if any(same_rule(rule, host, port, protocols) for rule in rules):
        continue
    rules.append({
        "name": f"{host}:{port}",
        "host": host,
        "port": port,
        "protocols": protocols,
        "enabled": True,
        "created_at": now,
        "approved_at": now,
        "reason": "default packaged endpoint",
    })

tmp = path.with_suffix(path.suffix + ".tmp")
tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
tmp.replace(path)
PY
fi

chmod 700 "$base" "$base/policy" "$base/state"
chmod 755 "$base/policy/ssh-leases"
chmod 1777 "$base/requests"
chmod 600 "$base/policy/approvals.json" "$base/policy/ssh-allowlist.json"
chmod 600 "$token_file"

printf 'initialized hardened jail state at %s\n' "$base"
printf 'export JAIL_POLICY_DIR=%s/policy\n' "$base"
printf 'export JAIL_STATE_DIR=%s/state\n' "$base"
printf 'export JAIL_REQUEST_DIR=%s/requests\n' "$base"
printf 'export JAIL_SSH_BROKER_TOKEN_FILE=%s\n' "$token_file"
