        draw_text(stdscr, height - 1, 0, prompt[:max_x])
        stdscr.refresh()
        raw = stdscr.getstr(height - 1, min(len(prompt), max_x), 240)
    except KeyboardInterrupt as exc:
        raise OperatorExit from exc
    finally:
        curses.noecho()
    if raw in (b"\x03", b"\x04"):
        raise OperatorExit
    return raw.decode("utf-8").strip()


def approve_request(path, request, ttl, stdscr=None):
    clean_request = stored_request(request)
    kind = request.get("kind")
    if kind == "ssh-lease" or (kind == "ssh" and request.get("payload", {}).get("lease", {}).get("requested")):
        approve_ssh_lease(clean_request, ttl)
        mark_request_group(path, request, "approved", f"approved SSH lease for {ttl}")
        return
    if kind == "ssh":
        if stdscr is None:
            raise ValueError("SSH approval requires an interactive operator terminal")
        session = start_host_ssh_session(clean_request)
        mark_request_group(path, request, "approved", f"opened host SSH via {session['launcher']}: {session['attach']}")
        return
    rules = rules_for_request(clean_request)
    if not rules:
        raise ValueError(f"{kind} requests cannot be auto-approved by this operator")
    reason = request.get("payload", {}).get("reason") or summarize(request)
    add_rules(rules, ttl, reason)
    mark_request_group(path, request, "approved", f"approved egress for {ttl}")


