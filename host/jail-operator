def add_rules(rules, ttl, reason):
    data = load_approvals()
    now = utc_now()
    expires = expires_for_ttl(ttl)
    for rule in rules:
        entry = dict(rule)
        label = entry.get("host") or entry.get("host_suffix") or entry.get("host_glob") or "egress"
        entry.setdefault("name", f"{label}:{entry.get('port', 443)}")
        entry.setdefault("enabled", True)
        entry.setdefault("created_at", now.isoformat())
        entry["approved_at"] = now.isoformat()
        if expires is None:
            entry.pop("expires_at", None)
        else:
            entry["expires_at"] = expires.isoformat()
        entry["reason"] = reason
        data["rules"].append(entry)
    compact_approval_rules(data)
    write_json(APPROVALS, data, 0o600)


def add_blocks(rules, reason, request=None):
    data = load_approvals()
    blocks = data.setdefault("blocks", [])
    now = utc_now().isoformat()
    added = []
    for rule in rules:
        entry = dict(rule)
        label = entry.get("host") or entry.get("host_suffix") or entry.get("host_glob") or "egress"
        entry.setdefault("name", f"{label}:{entry.get('port', 443)}")
        entry.setdefault("enabled", True)
        entry.setdefault("created_at", now)
        entry["blocked_at"] = now
        entry["reason"] = reason
        if request:
            entry["source_request_id"] = request.get("id", "")
        if any(same_network_rule(existing, entry) for existing in blocks if isinstance(existing, dict)):
            continue
        blocks.append(entry)
        added.append(entry)
    write_json(APPROVALS, data, 0o600)
    return added


def same_network_rule(left, right):
    left_keys = {key: left.get(key) for key in ("host", "host_suffix", "host_glob", "port")}
    right_keys = {key: right.get(key) for key in ("host", "host_suffix", "host_glob", "port")}
    return left_keys == right_keys and set(left.get("protocols") or []) == set(right.get("protocols") or [])


def request_sort_time(request):
    return parse_time(request.get("last_seen_at") or request.get("created_at") or "") or dt.datetime.min.replace(tzinfo=dt.timezone.utc)


def request_files():
    found = []
    for path in REQUEST_DIR.glob("*.json"):
        request = read_json(path)
        if not isinstance(request, dict):
            continue
        if request.get("status", "pending") != "pending":
            continue
        found.append((path, request))
    return group_pending_requests(sorted(found, key=lambda item: request_sort_time(item[1]), reverse=True))


def request_group_key(request):
    payload = request.get("payload", {})
    kind = request.get("kind")
    if kind == "egress":
        return ("egress", str(payload.get("host", "")).lower().rstrip("."), int(payload.get("port") or 443))
    if kind in {"ssh", "ssh-lease"}:
        return (kind, payload.get("target_key") or payload.get("alias") or payload.get("target") or "")
    return (kind, request.get("dedupe_key") or json.dumps(payload, sort_keys=True))


def group_pending_requests(rows):
    grouped = []
    by_key = {}
    for path, request in rows:
        key = request_group_key(request)
        existing = by_key.get(key)
        if existing is None:
            request = dict(request)
            request["__group_paths"] = [str(path)]
            by_key[key] = (path, request)
            grouped.append((path, request))
            continue
        _existing_path, existing_request = existing
        existing_request["__group_paths"].append(str(path))
        existing_request["seen_count"] = int(existing_request.get("seen_count") or 1) + int(request.get("seen_count") or 1)
        if request_sort_time(request) > request_sort_time(existing_request):
            existing_request["last_seen_at"] = request.get("last_seen_at") or request.get("created_at")
        existing_payload = existing_request.setdefault("payload", {})
        payload = request.get("payload", {})
        if request.get("kind") in {"ssh", "ssh-lease"}:
            existing_request["payload"] = merge_ssh_payload(existing_payload, payload)
            continue
        protocols = sorted(set(existing_payload.get("protocols") or []) | set(payload.get("protocols") or []))
        if protocols:
            existing_payload["protocols"] = protocols
    return grouped


def request_group_paths(path, request):
    paths = request.get("__group_paths") if isinstance(request, dict) else None
    return [pathlib.Path(value) for value in paths] if paths else [path]


def stored_request(request):
    return {key: value for key, value in request.items() if not key.startswith("__")}


def mark_request_group(path, request, status, reason=""):
    count = 0
    for group_path in request_group_paths(path, request):
        current = read_json(group_path, {})
        if not isinstance(current, dict):
            current = stored_request(request)
        mark_request(group_path, current, status, reason)
        count += 1
    return count


def summarize(request):
    kind = request.get("kind", "?")
    payload = request.get("payload", {})
    if kind == "egress":
        return f"egress {payload.get('host', '?')}:{payload.get('port', 443)}"
    if kind == "install":
        args = " ".join(payload.get("arguments") or [])
        return f"install {payload.get('manager', '?')} {args}".strip()
    if kind == "agent-login":
        return f"agent-login {payload.get('agent', '?')}"
    if kind in {"ssh", "ssh-lease"}:
        return f"{kind} {payload.get('target') or payload.get('target_key') or payload.get('alias', '?')}"
    return kind


def egress_rules_from_request(request):
    payload = request.get("payload", {})
    host = payload.get("host")
    if not host:
        return []
    return [{
        "host": host,
        "port": int(payload.get("port") or 443),
        "protocols": payload.get("protocols") or ["connect"],
    }]


def preset_rules(name):
    return [dict(rule) for rule in PRESETS.get(name, [])]


def rules_for_request(request):
    kind = request.get("kind")
    payload = request.get("payload", {})
    if kind == "egress":
        return egress_rules_from_request(request)
    if kind == "install":
        return preset_rules(INSTALL_PRESETS.get(payload.get("manager"), "github-https"))
    if kind == "agent-login":
        agent = payload.get("agent")
        return preset_rules(f"{agent}-login")
    return []


def mark_request(path, request, status, reason=""):
    updated = dict(request)
    updated["status"] = status
    updated["decided_at"] = utc_now().isoformat()
    if reason:
        updated["decision_reason"] = reason
    write_json(path, updated, 0o666)


def update_request(path, updates):
    current = read_json(path, {})
    if not isinstance(current, dict):
        current = {}
    current.update(updates)
    write_json(path, current, 0o666)


def revoke_approval(rule_index):
    data = load_approvals()
    rules = data.get("rules", [])
    if rule_index < 0 or rule_index >= len(rules):
        raise ValueError("approval no longer exists")
    removed = rules.pop(rule_index)
    write_json(APPROVALS, data, 0o600)
    return removed


def revoke_block(rule_index):
    data = load_approvals()
    blocks = data.get("blocks", [])
    if rule_index < 0 or rule_index >= len(blocks):
        raise ValueError("block no longer exists")
    removed = blocks.pop(rule_index)
    write_json(APPROVALS, data, 0o600)
    return removed


def revoke_ssh_block(alias):
    data = load_ssh_policy()
    blocks = data.get("blocks", {})
    if alias not in blocks:
        raise ValueError("SSH block no longer exists")
    removed = blocks.pop(alias)
    if not isinstance(removed, dict):
        removed = {"alias": alias}
    removed.setdefault("alias", alias)
    write_ssh_policy(data)
    return removed


def remove_ssh_alias(alias):
    data = load_ssh_policy()
    aliases = data.get("aliases", {})
    if alias not in aliases:
        raise ValueError("SSH alias no longer exists")
    removed = aliases.pop(alias)
    if not isinstance(removed, dict):
        removed = {"alias": alias}
    removed.setdefault("alias", alias)
    write_ssh_policy(data)
    return removed


def set_approval_ttl(rule_index, ttl):
    data = load_approvals()
    rules = data.get("rules", [])
    if rule_index < 0 or rule_index >= len(rules):
        raise ValueError("approval no longer exists")
    rule = rules[rule_index]
    if not isinstance(rule, dict):
        raise ValueError("approval rule is malformed")
    expires = expires_for_ttl(ttl)
    if expires is None:
        rule.pop("expires_at", None)
    else:
        rule["expires_at"] = expires.isoformat()
    rule["ttl_updated_at"] = utc_now().isoformat()
    write_json(APPROVALS, data, 0o600)
    return rule


def block_request(path, request):
    clean_request = stored_request(request)
    if request.get("kind") in {"ssh", "ssh-lease"}:
        added = block_ssh_request(clean_request)
        mark_request_group(path, request, "denied", "forever denied by host operator")
        return added
    rules = rules_for_request(clean_request)
    if not rules:
        raise ValueError(f"{request.get('kind')} requests cannot be blocklisted by this operator")
    reason = request.get("payload", {}).get("reason") or summarize(request)
    added = add_blocks(rules, reason, clean_request)
    mark_request_group(path, request, "denied", "forever denied by host operator")
    return added


def ssh_target_key(payload, entry=None):
    if payload.get("target_key"):
        return payload["target_key"]
    if payload.get("alias"):
        return payload["alias"]
    source = entry or payload
    host = source.get("host")
    if not host:
        return ""
    user = source.get("user", "")
    port = int(source.get("port") or 22)
    return f"{user + '@' if user else ''}{host}:{port}"


def ssh_block_keys(payload, entry=None):
    keys = []
    for key in (payload.get("target_key"), payload.get("alias"), ssh_target_key(payload, entry)):
        if key and key not in keys:
            keys.append(key)
    return keys


def ssh_request_blocked(payload, entry=None):
    blocks = ssh_blocks()
    return next((key for key in ssh_block_keys(payload, entry) if key in blocks), "")


def ssh_entry_from_payload(payload):
    if payload.get("host"):
        return {
            "host": payload["host"],
            "user": payload.get("user", ""),
            "port": int(payload.get("port") or 22),
            "features": payload.get("features") or {},
        }
    alias = payload.get("alias")
    if not alias:
        raise ValueError("SSH request is missing target host or alias")
    aliases = load_ssh_allowlist()
    if alias not in aliases:
        raise ValueError(f"unknown SSH alias: {alias}; direct requests should include user@host")
    entry = dict(aliases[alias])
    entry.setdefault("alias", alias)
    return entry


def block_ssh_request(request):
    payload = request.get("payload", {})
    try:
        entry = ssh_entry_from_payload(payload)
    except ValueError:
        entry = {}
    key = ssh_target_key(payload, entry)
    if not key:
        raise ValueError("SSH request is missing target")
    entry = dict(entry)
    if payload.get("alias"):
        entry["alias"] = payload["alias"]
    entry["target_key"] = key
    entry["blocked_at"] = utc_now().isoformat()
    entry["reason"] = payload.get("reason") or summarize(request)
    entry["source_request_id"] = request.get("id", "")
    policy = load_ssh_policy()
    policy.setdefault("blocks", {})[key] = entry
    write_ssh_policy(policy)
    return [entry]


def block_ssh_alias(alias):
    policy = load_ssh_policy()
    aliases = policy.get("aliases", {})
    entry = dict(aliases.pop(alias, {}))
    if not entry:
        raise ValueError("SSH alias no longer exists")
    entry["alias"] = alias
    entry["blocked_at"] = utc_now().isoformat()
    entry["reason"] = "blocked by host operator"
    policy.setdefault("blocks", {})[alias] = entry
    write_ssh_policy(policy)
    return entry


def ssh_alias_blocked(alias):
    return alias in ssh_blocks()


def add_ssh_alias(stdscr):
    alias = prompt_line(stdscr, "ssh alias: ")
    if not alias:
        raise ValueError("alias is required")
    if any(char.isspace() for char in alias):
        raise ValueError("alias cannot contain whitespace")
    host = prompt_line(stdscr, "ssh host: ")
    if not host:
        raise ValueError("host is required")
    user = prompt_line(stdscr, f"ssh user [{os.environ.get('USER', '')}]: ") or os.environ.get("USER", "")
    port_text = prompt_line(stdscr, "ssh port [22]: ") or "22"
    identity = prompt_line(stdscr, "identity file [optional]: ")
    command = prompt_line(stdscr, "default remote command [optional]: ")
    entry = {
        "host": host,
        "user": user,
        "port": int(port_text),
        "features": {
            "agent_forwarding": False,
            "x11_forwarding": False,
            "port_forwarding": False,
        },
        "created_at": utc_now().isoformat(),
    }
    if identity:
        entry["identity_file"] = identity
    if command:
        entry["command"] = command
    policy = load_ssh_policy()
    if alias in policy.get("blocks", {}):
        raise ValueError("alias is blocklisted; remove it from blacklist first")
    policy.setdefault("aliases", {})[alias] = entry
    write_ssh_policy(policy)
    return alias, entry


def request_scope(request):
    payload = request.get("payload", {})
    return payload.get("scope") or payload.get("lease", {}).get("scope") or {}


def request_scopes(request):
    payload = request.get("payload", {})
    scopes = [scope for scope in payload.get("scopes") or [] if isinstance(scope, dict) and scope]
    scope = request_scope(request)
    if scope:
        key = (scope.get("sid"), scope.get("pgid"), scope.get("pid"), scope.get("uid"))
        if not any((item.get("sid"), item.get("pgid"), item.get("pid"), item.get("uid")) == key for item in scopes):
            scopes.append(scope)
    return scopes


def approve_ssh_lease(request, ttl):
    payload = request.get("payload", {})
    scopes = request_scopes(request)
    if not scopes:
        raise ValueError("SSH lease request is missing process scope")
    entry = ssh_entry_from_payload(payload)
    blocked_key = ssh_request_blocked(payload, entry)
    if blocked_key:
        raise ValueError(f"SSH target is blocklisted: {blocked_key}")
    target_key = ssh_target_key(payload, entry)
    if not target_key:
        raise ValueError("SSH lease request is missing target")
    expires = expires_for_ttl(ttl)
    lease_id = f"{utc_now().strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:12]}"
    lease = {
        "id": lease_id,
        "alias": payload.get("alias", ""),
        "target": payload.get("target", target_key),
        "target_key": target_key,
        "host": entry.get("host", ""),
        "user": entry.get("user", ""),
        "port": int(entry.get("port") or 22),
        "created_at": utc_now().isoformat(),
        "scope": {
            "sid": scopes[0].get("sid"),
            "pgid": scopes[0].get("pgid"),
            "uid": scopes[0].get("uid"),
        },
        "scopes": [
            {
                "sid": scope.get("sid"),
                "pgid": scope.get("pgid"),
                "pid": scope.get("pid"),
                "uid": scope.get("uid"),
            }
            for scope in scopes
        ],
        "process_anchors": process_anchors(scopes),
        "request_id": request.get("id"),
        "features": {
            "agent_forwarding": False,
            "x11_forwarding": False,
            "port_forwarding": False,
        },
    }
    if expires is not None:
        lease["expires_at"] = expires.isoformat()
    write_json(LEASE_DIR / f"{lease_id}.json", lease, 0o644)


def live_ssh_lease_for_payload(payload):
    try:
        entry = ssh_entry_from_payload(payload)
    except ValueError:
        entry = {}
    target_key = ssh_target_key(payload, entry)
    if not target_key:
        return None, None
    now = utc_now()
    request_scope_value = payload.get("scope") or payload.get("lease", {}).get("scope") or {}
    request_sid = request_scope_value.get("sid")
    request_pgid = request_scope_value.get("pgid")
    request_anchor_keys = {anchor_key(anchor) for anchor in process_anchors([request_scope_value])}
    candidates = []
    for path in sorted(LEASE_DIR.glob("*.json")):
        lease = read_json(path)
        if not isinstance(lease, dict):
            continue
        lease_key = lease.get("target_key") or lease.get("alias")
        if lease_key != target_key:
            continue
        expires_at = parse_time(lease.get("expires_at"))
        if expires_at and now >= expires_at:
            continue
        scopes = [scope for scope in lease.get("scopes") or [] if isinstance(scope, dict)]
        if not scopes:
            scopes = [lease.get("scope", {})]
        if not any(scope.get("sid") or scope.get("pgid") for scope in scopes):
            candidates.append((path, lease))
            continue
        if any(
            (request_sid and scope.get("sid") == request_sid)
            or (request_pgid and scope.get("pgid") == request_pgid)
            for scope in scopes
        ):
            candidates.append((path, lease))
            continue
        lease_anchor_keys = {
            anchor_key(anchor)
            for anchor in (lease.get("process_anchors") or [])
            if isinstance(anchor, dict)
        }
        if request_anchor_keys and request_anchor_keys & lease_anchor_keys:
            candidates.append((path, lease))
    return candidates[-1] if candidates else (None, None)


def ssh_command_for_request(request):
    payload = request.get("payload", {})
    entry = ssh_entry_from_payload(payload)
    blocked_key = ssh_request_blocked(payload, entry)
    if blocked_key:
        raise ValueError(f"SSH target is blocklisted: {blocked_key}")
    alias = payload.get("alias", "")
    host = entry["host"]
    user = entry.get("user", os.environ.get("USER", ""))
    port = int(entry.get("port", 22))
    identity = entry.get("identity_file")
    command = payload.get("remote_command") or entry.get("command", "")
    remote_args = payload.get("remote_args") or []
    features = entry.get("features", {})
    if features.get("agent_forwarding") or features.get("x11_forwarding") or features.get("port_forwarding"):
        raise ValueError("forwarding features are intentionally not supported by this operator")
    target = f"{user}@{host}" if user else host
    ssh_cmd = [
        os.environ.get("JAIL_HOST_SSH_COMMAND", "/usr/bin/ssh"),
        *(payload.get("ssh_options") or []),
        "-p", str(port),
        "-o", "ForwardAgent=no",
        "-o", "ForwardX11=no",
        "-o", "PermitLocalCommand=no",
        "-o", "ExitOnForwardFailure=yes",
        "-o", "ClearAllForwardings=yes",
    ]
    if identity:
        ssh_cmd.extend(["-i", os.path.expanduser(identity)])
    ssh_cmd.append(target)
    if remote_args:
        ssh_cmd.extend(str(arg) for arg in remote_args)
    elif command:
        ssh_cmd.append(command)
    return alias or payload.get("target_key", target), target, command, ssh_cmd


def ssh_session_name(request, target):
    raw = "".join(char if char.isalnum() else "-" for char in target.lower()).strip("-")
    return f"jail-ssh-{raw[:24]}-{request.get('id', uuid.uuid4().hex)[:8]}"


def ssh_terminal_command(ssh_cmd):
    return (
        f"{shlex.join(ssh_cmd)}; "
        "status=$?; "
        "printf '\\nSSH exited with status %s\\n' \"$status\"; "
        "exec \"${SHELL:-/bin/sh}\" -l"
    )


def launch_ssh_terminal(session, ssh_cmd):
    command = ssh_terminal_command(ssh_cmd)
    if shutil.which("tmux"):
        subprocess.check_call(["tmux", "new-session", "-d", "-s", session, *ssh_cmd])
        return {
            "launcher": "tmux",
            "attach": f"tmux attach -t {session}",
        }

    if shutil.which("osascript"):
        script = f'tell application "Terminal" to do script {json.dumps(command)}'
        subprocess.check_call(["osascript", "-e", script])
        return {
            "launcher": "Terminal.app",
            "attach": "use the new Terminal window",
        }

    terminal_commands = [
        ("gnome-terminal", ["gnome-terminal", "--", "sh", "-lc", command]),
        ("x-terminal-emulator", ["x-terminal-emulator", "-e", "sh", "-lc", command]),
        ("konsole", ["konsole", "-e", "sh", "-lc", command]),
        ("kitty", ["kitty", "sh", "-lc", command]),
        ("alacritty", ["alacritty", "-e", "sh", "-lc", command]),
        ("xterm", ["xterm", "-e", "sh", "-lc", command]),
    ]
    for name, cmd in terminal_commands:
        if shutil.which(name):
            subprocess.Popen(cmd)
            return {
                "launcher": name,
                "attach": f"use the new {name} window",
            }

    raise ValueError("no non-blocking SSH launcher found; install tmux or use a supported terminal app")


def start_host_ssh_session(request):
    alias, target, command, ssh_cmd = ssh_command_for_request(request)
    session = ssh_session_name(request, target)
    launched = launch_ssh_terminal(session, ssh_cmd)
    return {
        "alias": alias,
        "target": target,
        "command": command,
        "session": session,
        **launched,
        "exec": shlex.join(ssh_cmd),
    }


def set_pty_size(fd, winsize):
    try:
        rows = int(winsize.get("rows") or 24)
        cols = int(winsize.get("cols") or 80)
        fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack("HHHH", rows, cols, 0, 0))
    except Exception:
        pass


def wait_for_operator_resolution(path, send_error, timeout=0):
    deadline = time.time() + timeout if timeout else None
    while True:
        request = read_json(path, {})
        status = request.get("status", "pending") if isinstance(request, dict) else "pending"
        if status == "approved":
            return True
        if status == "denied":
            reason = request.get("decision_reason") or "denied by host operator"
            send_error(f"ssh broker: request denied: {reason}\n")
            return False
        if deadline and time.time() >= deadline:
            send_error("ssh broker: timed out waiting for host approval\n")
            return False
        time.sleep(0.5)


def broker_payload_from_client(client_request):
    payload = dict(client_request.get("payload") or {})
    payload["brokered"] = True
    payload.setdefault("features", {
        "agent_forwarding": False,
        "x11_forwarding": False,
        "port_forwarding": False,
    })
    payload["lease"] = {
        "requested": True,
        "scope": payload.get("scope") or {},
        "ttl": payload.get("ttl") or "30m",
    }
    return payload


def run_brokered_ssh(sock, client_request, send_lock):
    payload = broker_payload_from_client(client_request)
    send_error = lambda text: frame_send(sock, FRAME_STDERR, text, send_lock)
    session_id = ""
    try:
        entry = ssh_entry_from_payload(payload)
        blocked_key = ssh_request_blocked(payload, entry)
        if blocked_key:
            send_error(f"ssh broker: target is blocklisted: {blocked_key}\n")
            frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": 126}), send_lock)
            return
        lease_path, _lease = live_ssh_lease_for_payload(payload)
        if not lease_path:
            path, _request = write_or_merge_ssh_request(payload)
            send_error("ssh broker: waiting for host operator approval\n")
            if not wait_for_operator_resolution(path, send_error):
                frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": 1}), send_lock)
                return
            lease_path, _lease = live_ssh_lease_for_payload(payload)
            if not lease_path:
                send_error("ssh broker: approved, but no matching SSH lease was created\n")
                frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": 1}), send_lock)
                return
        request = {"payload": payload, "id": client_request.get("id", "")}
        _alias, _target, _command, ssh_cmd = ssh_command_for_request(request)
        use_pty = bool(client_request.get("tty")) and payload.get("tty_mode") != "disable"
        if payload.get("tty_mode") == "force":
            use_pty = True
        session_id = register_ssh_session(payload, ssh_cmd, use_pty, lease_path)
        exit_status = run_ssh_with_pty(sock, ssh_cmd, client_request.get("winsize") or {}, send_lock) if use_pty else run_ssh_with_pipes(sock, ssh_cmd, send_lock)
        update_ssh_session(session_id, status="completed", exit_status=exit_status, completed_at=utc_now().isoformat())
        frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": exit_status}), send_lock)
    except Exception as exc:
        update_ssh_session(session_id, status="failed", error=str(exc), completed_at=utc_now().isoformat(), exit_status=1)
        send_error(f"ssh broker: {exc}\n")
        try:
            frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": 1}), send_lock)
        except OSError:
            pass


def pump_socket_to_pipe(sock, stdin_pipe, send_lock):
    try:
        while True:
            channel, data = frame_recv(sock)
            if channel is None or channel == FRAME_STDIN_EOF:
                break
            if channel == FRAME_STDIN and data:
                stdin_pipe.write(data)
                stdin_pipe.flush()
    except (BrokenPipeError, EOFError, OSError):
        pass
    finally:
        try:
            stdin_pipe.close()
        except OSError:
            pass


def pump_pipe_to_socket(pipe, sock, channel, send_lock):
    try:
        while True:
            data = os.read(pipe.fileno(), 32768)
            if not data:
                break
            frame_send(sock, channel, data, send_lock)
    except OSError:
        pass


def run_ssh_with_pipes(sock, ssh_cmd, send_lock):
    proc = subprocess.Popen(ssh_cmd, stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    threads = [
        threading.Thread(target=pump_socket_to_pipe, args=(sock, proc.stdin, send_lock), daemon=True),
        threading.Thread(target=pump_pipe_to_socket, args=(proc.stdout, sock, FRAME_STDOUT, send_lock), daemon=True),
        threading.Thread(target=pump_pipe_to_socket, args=(proc.stderr, sock, FRAME_STDERR, send_lock), daemon=True),
    ]
    for thread in threads:
        thread.start()
    status = proc.wait()
    for thread in threads[1:]:
        thread.join(timeout=1)
    return status


def pump_socket_to_pty(sock, master_fd):
    try:
        while True:
            channel, data = frame_recv(sock)
            if channel is None:
                break
            if channel == FRAME_STDIN and data:
                os.write(master_fd, data)
            elif channel == FRAME_RESIZE:
                try:
                    set_pty_size(master_fd, json.loads(data.decode("utf-8")))
                except json.JSONDecodeError:
                    pass
            elif channel == FRAME_STDIN_EOF:
                break
    except (EOFError, OSError):
        pass


def pump_pty_to_socket(master_fd, sock, send_lock):
    try:
        while True:
            try:
                data = os.read(master_fd, 32768)
            except OSError as exc:
                if exc.errno == errno.EIO:
                    break
                raise
            if not data:
                break
            frame_send(sock, FRAME_STDOUT, data, send_lock)
    except OSError:
        pass


def run_ssh_with_pty(sock, ssh_cmd, winsize, send_lock):
    master_fd, slave_fd = pty.openpty()
    set_pty_size(master_fd, winsize)
    proc = subprocess.Popen(ssh_cmd, stdin=slave_fd, stdout=slave_fd, stderr=slave_fd, close_fds=True)
    os.close(slave_fd)
    threads = [
        threading.Thread(target=pump_socket_to_pty, args=(sock, master_fd), daemon=True),
        threading.Thread(target=pump_pty_to_socket, args=(master_fd, sock, send_lock), daemon=True),
    ]
    for thread in threads:
        thread.start()
    status = proc.wait()
    try:
        os.close(master_fd)
    except OSError:
        pass
    return status


def handle_broker_client(sock, _addr):
    send_lock = threading.Lock()
    try:
        client_request = recv_json_line(sock)
        token = read_broker_token()
        if not token or client_request.get("token") != token:
            frame_send(sock, FRAME_STDERR, "ssh broker: authentication failed\n", send_lock)
            frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": 126}), send_lock)
            return
        run_brokered_ssh(sock, client_request, send_lock)
    except Exception as exc:
        try:
            frame_send(sock, FRAME_STDERR, f"ssh broker: {exc}\n", send_lock)
            frame_send(sock, FRAME_EXIT, json.dumps({"exit_status": 1}), send_lock)
        except OSError:
            pass
    finally:
        try:
            sock.close()
        except OSError:
            pass


def ssh_broker_server():
    token = read_broker_token()
    if not token:
        broker_status(f"ssh broker: token missing at {BROKER_TOKEN_FILE}")
        return
    try:
        server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server.bind((BROKER_BIND, BROKER_PORT))
        server.listen(64)
    except OSError as exc:
        broker_status(f"ssh broker: failed to bind {BROKER_BIND}:{BROKER_PORT}: {exc}")
        return
    broker_status(f"ssh broker: listening on {BROKER_BIND}:{BROKER_PORT}")
    while True:
        try:
            client, addr = server.accept()
        except OSError as exc:
            broker_status(f"ssh broker: accept failed: {exc}")
            return
        threading.Thread(target=handle_broker_client, args=(client, addr), daemon=True).start()


def start_ssh_broker():
    thread = threading.Thread(target=ssh_broker_server, name="ssh-broker", daemon=True)
    thread.start()
    return thread


