def frame_send(sock, channel, data, lock=None):
    if isinstance(data, str):
        data = data.encode("utf-8")
    header = struct.pack(">BI", channel, len(data))
    if lock:
        with lock:
            sock.sendall(header + data)
    else:
        sock.sendall(header + data)


def frame_recv(sock):
    header = recv_exact(sock, 5)
    if not header:
        return None, b""
    channel, length = struct.unpack(">BI", header)
    return channel, recv_exact(sock, length)


def recv_exact(sock, size):
    chunks = []
    remaining = size
    while remaining:
        chunk = sock.recv(remaining)
        if not chunk:
            if chunks:
                raise EOFError("short frame read")
            return b""
        chunks.append(chunk)
        remaining -= len(chunk)
    return b"".join(chunks)


def recv_json_line(sock, limit=1024 * 1024):
    data = bytearray()
    while len(data) < limit:
        chunk = sock.recv(1)
        if not chunk:
            break
        if chunk == b"\n":
            break
        data.extend(chunk)
    if not data:
        return {}
    return json.loads(data.decode("utf-8"))


def ssh_request_dedupe_key(payload):
    raw = f"ssh:{payload.get('target_key') or payload.get('alias') or payload.get('target')}"
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()[:16]


def pending_request_by_dedupe(dedupe_key):
    for path in REQUEST_DIR.glob("*.json"):
        request = read_json(path)
        if not isinstance(request, dict):
            continue
        if request.get("status", "pending") != "pending":
            continue
        if request.get("dedupe_key") == dedupe_key:
            return path, request
    return None, None


def scope_identity(scope):
    return (scope.get("sid"), scope.get("pgid"), scope.get("pid"), scope.get("uid"))


def anchor_key(anchor):
    return (
        anchor.get("pid"),
        anchor.get("comm"),
        anchor.get("starttime"),
        anchor.get("uid"),
    )


def process_anchors(scopes):
    anchors = []
    seen = set()
    for scope in scopes:
        if not isinstance(scope, dict):
            continue
        uid = scope.get("uid")
        entries = list(scope.get("tree") or [])
        entries.append({
            "pid": scope.get("pid"),
            "comm": scope.get("comm", ""),
            "starttime": scope.get("starttime", ""),
        })
        for entry in entries:
            if not isinstance(entry, dict) or not entry.get("pid"):
                continue
            anchor = {
                "pid": entry.get("pid"),
                "comm": entry.get("comm", ""),
                "starttime": entry.get("starttime", ""),
                "uid": uid,
            }
            key = anchor_key(anchor)
            if key not in seen:
                anchors.append(anchor)
                seen.add(key)
    return anchors


def merge_ssh_payload(existing, incoming):
    merged = dict(existing)
    for key, value in incoming.items():
        if value not in (None, "", [], {}):
            merged[key] = value
    scopes = []
    seen = set()
    for scope in existing.get("scopes") or []:
        if isinstance(scope, dict) and scope_identity(scope) not in seen:
            scopes.append(scope)
            seen.add(scope_identity(scope))
    for scope in (existing.get("scope"), existing.get("lease", {}).get("scope"), incoming.get("scope"), incoming.get("lease", {}).get("scope")):
        if isinstance(scope, dict) and scope and scope_identity(scope) not in seen:
            scopes.append(scope)
            seen.add(scope_identity(scope))
    if scopes:
        merged["scopes"] = scopes
    return merged


def write_or_merge_ssh_request(payload):
    REQUEST_DIR.mkdir(parents=True, exist_ok=True)
    dedupe_key = ssh_request_dedupe_key(payload)
    now = utc_now().isoformat()
    path, request = pending_request_by_dedupe(dedupe_key)
    if path and request:
        request["last_seen_at"] = now
        request["seen_count"] = int(request.get("seen_count") or 1) + 1
        request["payload"] = merge_ssh_payload(request.get("payload", {}), payload)
        write_json(path, request, 0o666)
        return path, request
    request_id = f"{utc_now().strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:12]}"
    path = REQUEST_DIR / f"{request_id}.json"
    request = {
        "id": request_id,
        "kind": "ssh",
        "status": "pending",
        "dedupe_key": dedupe_key,
        "created_at": now,
        "last_seen_at": now,
        "seen_count": 1,
        "cwd": payload.get("cwd", ""),
        "payload": payload,
    }
    write_json(path, request, 0o666)
    return path, request


