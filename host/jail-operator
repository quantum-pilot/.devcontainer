def prune_expired_approvals():
    data = load_approvals()
    removed = compact_approval_rules(data)
    if removed:
        write_json(APPROVALS, data, 0o600)
    return removed


def compact_approval_rules(data):
    now = utc_now()
    rules = data.get("rules", [])
    compacted = []
    removed = 0
    for rule in rules:
        if not isinstance(rule, dict):
            compacted.append(rule)
            continue
        expires_at = parse_time(rule.get("expires_at")) if isinstance(rule, dict) else None
        if expires_at and expires_at <= now:
            removed += 1
            continue
        if not rule.get("enabled", True):
            compacted.append(rule)
            continue
        match_index = next(
            (idx for idx, existing in enumerate(compacted) if isinstance(existing, dict) and existing.get("enabled", True) and same_network_rule(existing, rule)),
            None,
        )
        if match_index is None:
            compacted.append(rule)
            continue
        compacted[match_index] = merge_approval_rule(compacted[match_index], rule)
        removed += 1
    data["rules"] = compacted
    return removed


def rule_ttl_rank(rule):
    expires = parse_time(rule.get("expires_at"))
    if not expires:
        return dt.datetime.max.replace(tzinfo=dt.timezone.utc)
    return expires


def merge_approval_rule(left, right):
    best = right if rule_ttl_rank(right) > rule_ttl_rank(left) else left
    merged = dict(best)
    created = min(
        parse_time(left.get("created_at") or "") or utc_now(),
        parse_time(right.get("created_at") or "") or utc_now(),
    )
    approved = max(approval_time(left), approval_time(right))
    merged["created_at"] = created.isoformat()
    merged["approved_at"] = approved.isoformat()
    latest = right if approval_time(right) >= approval_time(left) else left
    if latest.get("reason"):
        merged["reason"] = latest["reason"]
    return merged


