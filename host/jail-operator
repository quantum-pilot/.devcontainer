def utc_now():
    return dt.datetime.now(dt.timezone.utc)


def parse_time(value):
    if not value:
        return None
    if value.endswith("Z"):
        value = value[:-1] + "+00:00"
    parsed = dt.datetime.fromisoformat(value)
    if parsed.tzinfo is None:
        return parsed.replace(tzinfo=dt.timezone.utc)
    return parsed


def parse_ttl(value):
    if value in {"forever", "infinite", "inf", "never", "permanent"}:
        return None
    units = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    if not value or value[-1] not in units:
        raise ValueError("ttl must end in s, m, h, d, or be forever")
    return int(value[:-1]) * units[value[-1]]


def expires_for_ttl(ttl):
    seconds = parse_ttl(ttl)
    if seconds is None:
        return None
    return utc_now() + dt.timedelta(seconds=seconds)


def ttl_label(expires_at):
    expires = parse_time(expires_at)
    if not expires:
        return "forever"
    remaining = int((expires - utc_now()).total_seconds())
    if remaining <= 0:
        return "expired"
    days, remaining = divmod(remaining, 86400)
    hours, remaining = divmod(remaining, 3600)
    minutes, seconds = divmod(remaining, 60)
    if days:
        return f"{days}d {hours}h"
    if hours:
        return f"{hours}h {minutes}m"
    if minutes:
        return f"{minutes}m {seconds}s"
    return f"{seconds}s"


def timestamp_label(value):
    parsed = parse_time(value or "")
    if not parsed:
        return ""
    return parsed.astimezone(dt.timezone.utc).strftime("%Y-%m-%d %H:%M:%SZ")


def current_minute_label():
