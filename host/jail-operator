def ssh_session_target(payload):
    return payload.get("target_key") or payload.get("target") or payload.get("alias") or "?"


def ssh_session_command(payload):
    remote_args = payload.get("remote_args") or []
    if remote_args:
        return shlex.join(str(arg) for arg in remote_args)
    return payload.get("remote_command") or "interactive"


def register_ssh_session(payload, ssh_cmd, use_pty, lease_path):
    session_id = f"{utc_now().strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:8]}"
    session = {
        "id": session_id,
        "status": "running",
        "target": ssh_session_target(payload),
        "command": ssh_session_command(payload),
        "started_at": utc_now().isoformat(),
        "tty": bool(use_pty),
        "lease_path": str(lease_path or ""),
        "exec": shlex.join(ssh_cmd),
    }
    with SSH_SESSIONS_LOCK:
        SSH_SESSIONS[session_id] = session
    return session_id


def update_ssh_session(session_id, **updates):
    if not session_id:
        return
    with SSH_SESSIONS_LOCK:
        session = SSH_SESSIONS.get(session_id)
        if not session:
            return
        session.update(updates)


def session_recent(session, now):
    if session.get("status") == "running":
        return True
    completed = parse_time(session.get("completed_at") or "")
    started = parse_time(session.get("started_at") or "")
    latest = completed or started
    if not latest:
        return True
    return (now - latest).total_seconds() <= SSH_SESSION_HISTORY_SECONDS


def active_ssh_sessions():
    now = utc_now()
    with SSH_SESSIONS_LOCK:
        old_ids = [
            session_id
            for session_id, session in SSH_SESSIONS.items()
            if not session_recent(session, now)
        ]
        for session_id in old_ids:
            SSH_SESSIONS.pop(session_id, None)
        rows = [(session_id, dict(session)) for session_id, session in SSH_SESSIONS.items()]
    rows.sort(key=lambda item: parse_time(item[1].get("started_at") or "") or dt.datetime.min.replace(tzinfo=dt.timezone.utc), reverse=True)
    return rows


