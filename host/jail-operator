        f"expires: {timestamp_label(rule.get('expires_at')) or 'forever'}",
        f"reason: {rule.get('reason', '')}",
        "",
        "rule:",
    ]
    for line in json.dumps(rule, indent=2, sort_keys=True).splitlines():
        lines.append(f"  {line}")
    return lines


def block_detail_lines(rule):
    lines = [
        f"name: {rule.get('name', 'unnamed')}",
        f"state: {'enabled' if rule.get('enabled', True) else 'disabled'}",
        f"target: {approval_target(rule)}",
        f"protocols: {','.join(rule.get('protocols') or [])}",
        f"blocked: {timestamp_label(rule.get('blocked_at') or rule.get('created_at'))}",
        f"source request: {rule.get('source_request_id', '')}",
        f"reason: {rule.get('reason', '')}",
        "",
        "block:",
    ]
    for line in json.dumps(rule, indent=2, sort_keys=True).splitlines():
        lines.append(f"  {line}")
    return lines


