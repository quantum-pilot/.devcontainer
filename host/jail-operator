def utc_now():
    return dt.datetime.now(dt.timezone.utc)


def parse_time(value):
    if not value:
        return None
    if value.endswith("Z"):
        value = value[:-1] + "+00:00"
    parsed = dt.datetime.fromisoformat(value)
    if parsed.tzinfo is None:
        return parsed.replace(tzinfo=dt.timezone.utc)
    return parsed


def parse_ttl(value):
    if value in {"forever", "infinite", "inf", "never", "permanent"}:
        return None
    units = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    if not value or value[-1] not in units:
        raise ValueError("ttl must end in s, m, h, d, or be forever")
    return int(value[:-1]) * units[value[-1]]


def expires_for_ttl(ttl):
    seconds = parse_ttl(ttl)
    if seconds is None:
        return None
    return utc_now() + dt.timedelta(seconds=seconds)


def ttl_label(expires_at):
    expires = parse_time(expires_at)
    if not expires:
        return "forever"
    remaining = int((expires - utc_now()).total_seconds())
    if remaining <= 0:
        return "expired"
    days, remaining = divmod(remaining, 86400)
    hours, remaining = divmod(remaining, 3600)
    minutes, seconds = divmod(remaining, 60)
    if days:
        return f"{days}d {hours}h"
    if hours:
        return f"{hours}h {minutes}m"
    if minutes:
        return f"{minutes}m {seconds}s"
    return f"{seconds}s"


def timestamp_label(value):
    parsed = parse_time(value or "")
    if not parsed:
        return ""
    return parsed.astimezone(dt.timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")


def read_json(path, default=None):
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return default


def load_ssh_policy():
    data = read_json(ALLOWLIST, {"aliases": {}, "blocks": {}})
    if not isinstance(data, dict):
        return {"aliases": {}, "blocks": {}}
    aliases = data.get("aliases", {})
    blocks = data.get("blocks", {})
    data["aliases"] = aliases if isinstance(aliases, dict) else {}
    data["blocks"] = blocks if isinstance(blocks, dict) else {}
    return data


def load_ssh_allowlist():
    return load_ssh_policy()["aliases"]


def ssh_blocks():
    return load_ssh_policy()["blocks"]


def write_ssh_policy(data):
    data.setdefault("aliases", {})
    data.setdefault("blocks", {})
    write_json(ALLOWLIST, data, 0o600)


def write_json(path, data, mode=None):
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    if mode is not None:
        os.chmod(tmp, mode)
    tmp.replace(path)


def load_approvals():
    data = read_json(APPROVALS, {"rules": [], "blocks": []})
    if not isinstance(data, dict):
        return {"rules": [], "blocks": []}
    data.setdefault("rules", [])
    data.setdefault("blocks", [])
    return data


def prune_expired_approvals():
    data = load_approvals()
    now = utc_now()
    rules = []
    removed = 0
    for rule in data.get("rules", []):
        expires_at = parse_time(rule.get("expires_at")) if isinstance(rule, dict) else None
        if expires_at and expires_at <= now:
            removed += 1
            continue
        rules.append(rule)
    if removed:
        data["rules"] = rules
        write_json(APPROVALS, data, 0o600)
    return removed


def active_approvals(sort_mode):
    prune_expired_approvals()
    rows = []
    for idx, rule in enumerate(load_approvals().get("rules", [])):
        if not isinstance(rule, dict):
            continue
        if not rule.get("enabled", True):
            continue
        expires_at = parse_time(rule.get("expires_at"))
        if expires_at and expires_at <= utc_now():
            continue
        rows.append((idx, rule))
    if sort_mode == "alpha":
        rows.sort(key=lambda item: approval_sort_text(item[1]))
    else:
        rows.sort(key=lambda item: approval_time(item[1]), reverse=True)
    return rows


def active_blacklist(sort_mode):
    rows = []
    for idx, rule in enumerate(load_approvals().get("blocks", [])):
        if not isinstance(rule, dict):
            continue
        if not rule.get("enabled", True):
            continue
        rows.append(("egress", idx, rule))
    for alias, entry in ssh_blocks().items():
        if not isinstance(entry, dict):
            entry = {"alias": alias}
        entry.setdefault("alias", alias)
        rows.append(("ssh", alias, entry))
    if sort_mode == "alpha":
        rows.sort(key=lambda item: blacklist_sort_text(item[0], item[2]))
    else:
        rows.sort(key=lambda item: blacklist_time(item[0], item[2]), reverse=True)
    return rows


def approval_time(rule):
    return parse_time(rule.get("approved_at") or rule.get("created_at") or "") or dt.datetime.min.replace(tzinfo=dt.timezone.utc)


def block_time(rule):
    return parse_time(rule.get("blocked_at") or rule.get("created_at") or "") or dt.datetime.min.replace(tzinfo=dt.timezone.utc)


def blacklist_time(kind, entry):
    if kind == "ssh":
        return parse_time(entry.get("blocked_at") or entry.get("created_at") or "") or dt.datetime.min.replace(tzinfo=dt.timezone.utc)
    return block_time(entry)


def approval_sort_text(rule):
    label = rule.get("name") or rule.get("host") or rule.get("host_suffix") or rule.get("host_glob") or ""
    return f"{label}:{rule.get('port', '')}".lower()


def blacklist_sort_text(kind, entry):
    if kind == "ssh":
        return f"ssh:{entry.get('alias', '')}:{entry.get('host', '')}".lower()
    return f"egress:{approval_sort_text(entry)}"


