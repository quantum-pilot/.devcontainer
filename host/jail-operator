    return entry.get("comm") or ""


def request_process_lines(request):
    scopes = request_scopes(request)
    if not scopes:
        return []
    lines = ["", "process:"]
    for scope_index, scope in enumerate(scopes, 1):
        lines.append(
            f"  scope {scope_index}: pid={scope.get('pid', '')} ppid={scope.get('ppid', '')} "
            f"sid={scope.get('sid', '')} pgid={scope.get('pgid', '')} uid={scope.get('uid', '')}"
        )
        command = process_command_label(scope)
        if command:
            lines.append(f"    command: {command}")
        tree = [entry for entry in scope.get("tree") or [] if isinstance(entry, dict)]
        if tree:
            lines.append("    ancestry:")
            for entry in tree:
                label = process_command_label(entry)
                if not label:
                    label = entry.get("comm", "")
                lines.append(
                    f"      pid={entry.get('pid', '')} comm={entry.get('comm', '')} "
                    f"start={entry.get('starttime', '')} {label}"
                )
    return lines


