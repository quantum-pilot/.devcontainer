def fit_cell(value, width, align="left"):
    text = str(value or "")
    if width <= 0:
        return ""
    if len(text) > width:
        return text[: max(0, width - 1)] + "~" if width > 1 else text[:1]
    if align == "right":
        return text.rjust(width)
    return text.ljust(width)


def compact_reason(value):
    text = str(value or "").strip()
    lowered = text.lower()
    if lowered.startswith("auto request after denied connect"):
        return "AUTO_DENIED_CONNECT"
    if lowered.startswith("auto request after denied http"):
        return "AUTO_DENIED_HTTP"
    if lowered == "default agent/headroom endpoint":
        return "DEFAULT_AGENT_HEADROOM"
    if lowered == "denied by host operator":
        return "OPERATOR_DENIED"
    if lowered == "blocked by host operator":
        return "OPERATOR_BLOCKED"
    if text.isupper() and all(char.isalnum() or char == "_" for char in text):
        return text
    cleaned = []
    previous_underscore = False
    for char in text.upper():
        if char.isalnum():
            cleaned.append(char)
            previous_underscore = False
        elif not previous_underscore:
            cleaned.append("_")
            previous_underscore = True
    return "".join(cleaned).strip("_") or "-"


def target_from_request(request):
    payload = request.get("payload", {})
    kind = request.get("kind")
    if kind == "egress":
        return f"{payload.get('host', '?')}:{payload.get('port', 443)}"
    if kind in {"ssh", "ssh-lease"}:
        return payload.get("target") or payload.get("target_key") or payload.get("alias") or "?"
    if kind == "install":
        args = " ".join(payload.get("arguments") or [])
        return f"{payload.get('manager', '?')} {args}".strip()
    if kind == "agent-login":
        return payload.get("agent", "?")
    return kind or "?"


def request_reason(request):
    payload = request.get("payload", {})
    return compact_reason(payload.get("reason") or payload.get("deny_reason") or request.get("decision_reason") or "")


def row_with_reason(prefix, target, reason, width, min_target_width=16, reason_width=24, target_width=None):
    remaining = max(0, width - len(prefix) - 1)
    if remaining <= min_target_width:
        return prefix + fit_cell(target, remaining)
    reason_label = compact_reason(reason)
    actual_reason_width = min(reason_width, max(0, remaining - min_target_width - 1))
    max_target_width = max(min_target_width, remaining - actual_reason_width - 1)
    target_width = min(max_target_width, max(min_target_width, target_width or max_target_width))
    if actual_reason_width <= 0:
        return prefix + fit_cell(target, remaining)
    return prefix + fit_cell(target, target_width) + "  " + fit_cell(reason_label, actual_reason_width)


def visible_target_width(view, rows, width):
    targets = []
    for item in rows:
        if view == "pending":
            _path, request = item
            targets.append(target_from_request(request))
        elif view == "blacklist":
            kind, _rule_index, entry = item
            targets.append(ssh_alias_target(entry) if kind == "ssh" else approval_target(entry))
        elif view == "approvals":
            _rule_index, rule = item
            targets.append(approval_target(rule))
    if not targets:
        return 16
    return max(16, min(max(len(target) for target in targets), 34, max(16, width // 2)))


