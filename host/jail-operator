def approval_target(rule):
    host = rule.get("host") or rule.get("host_suffix") or rule.get("host_glob") or "?"
    return f"{host}:{rule.get('port', 443)}"


def ssh_alias_target(entry):
    host = entry.get("host", "?")
    user = entry.get("user", "")
    port = entry.get("port", 22)
    target = f"{user}@{host}" if user else host
    return f"{target}:{port}"


def prompt_line(stdscr, prompt):
    curses.echo()
    height, width = stdscr.getmaxyx()
    draw_text(stdscr, height - 1, 0, " " * (width - 1))
    draw_text(stdscr, height - 1, 0, prompt)
    stdscr.refresh()
    value = stdscr.getstr(height - 1, min(len(prompt), width - 2), 240).decode("utf-8").strip()
    curses.noecho()
    return value


def approve_request(path, request, ttl, stdscr=None):
    kind = request.get("kind")
    if kind == "ssh-lease" or (kind == "ssh" and request.get("payload", {}).get("lease", {}).get("requested")):
        approve_ssh_lease(request, ttl)
        mark_request(path, request, "approved", f"approved SSH lease for {ttl}")
        return
    if kind == "ssh":
        if stdscr is None:
            raise ValueError("SSH approval requires an interactive operator terminal")
        ssh_command_for_request(request)
        mark_request(path, request, "approved", "approved and opened host-side SSH session")
        run_host_ssh(stdscr, request)
        return
    rules = rules_for_request(request)
    if not rules:
        raise ValueError(f"{kind} requests cannot be auto-approved by this operator")
    reason = request.get("payload", {}).get("reason") or summarize(request)
    add_rules(rules, ttl, reason)
    mark_request(path, request, "approved", f"approved egress for {ttl}")


def page_size(height):
    return max(1, height - 10)


def move_page(index, count, height, direction):
    if not count:
        return 0
    delta = page_size(height) * direction
    return min(max(index + delta, 0), count - 1)


def draw_wrapped_lines(stdscr, y, width, lines, max_y):
    for line in lines:
        for wrapped in textwrap.wrap(line, width=max(20, width - 2)) or [""]:
            draw_text(stdscr, y, 0, wrapped)
            y += 1
            if y >= max_y:
                return y
    return y


def help_text_for_view(view):
    common = "tab view  s sort  arrows move  pg/space page  enter details"
    if view == "pending":
        return f"{common}  +/- ttl  a approve  d deny  x forever deny  q quit"
    if view == "approvals":
        return f"{common}  +/- ttl  t set ttl  r revoke  q quit"
    if view == "blacklist":
        return f"{common}  r remove block  q quit"
    if view == "ssh":
        return f"{common}  n add alias  r remove alias  x block alias  q quit"
    return f"{common}  q quit"


def app(stdscr):
    curses.curs_set(0)
    stdscr.keypad(True)
    stdscr.timeout(REFRESH_MS)
    index = 0
    approval_index = 0
    block_index = 0
    ssh_index = 0
    ttl_index = 1
    view = "pending"
    sort_index = 0
    show_detail = True
    message = ""
    while True:
        removed = prune_expired_approvals()
        sort_mode = SORT_CHOICES[sort_index]
        requests = request_files(sort_mode)
        approvals = active_approvals(sort_mode)
        blocks = active_blacklist(sort_mode)
        ssh_aliases = active_ssh_aliases(sort_mode)
        if index >= len(requests):
            index = max(0, len(requests) - 1)
        if approval_index >= len(approvals):
            approval_index = max(0, len(approvals) - 1)
        if block_index >= len(blocks):
            block_index = max(0, len(blocks) - 1)
        if ssh_index >= len(ssh_aliases):
            ssh_index = max(0, len(ssh_aliases) - 1)
        stdscr.erase()
        height, width = stdscr.getmaxyx()
        if view == "pending":
            active_rows = requests
            active_index = index
        elif view == "approvals":
            active_rows = approvals
            active_index = approval_index
        elif view == "blacklist":
            active_rows = blocks
            active_index = block_index
        else:
            active_rows = ssh_aliases
            active_index = ssh_index
        help_text = help_text_for_view(view)
        draw_text(stdscr, 0, 0, "Hardened Jail Operator", curses.A_BOLD)
        draw_text(stdscr, 1, 0, f"home: {BASE}")
        draw_text(stdscr, 2, 0, f"view: {view}   pending: {len(requests)}   approvals: {len(approvals)}   blacklist: {len(blocks)}   ssh: {len(ssh_aliases)}   ttl: {TTL_CHOICES[ttl_index]}   sort: {sort_mode}")
        status = message or (f"removed {removed} expired approval(s)" if removed else help_text)
        draw_text(stdscr, 3, 0, status[: width - 1])
        list_height = page_size(height)
        start = max(0, min(active_index, max(0, len(active_rows) - list_height)))
        for row, item in enumerate(active_rows[start:start + list_height]):
            item_index = start + row
            attr = curses.A_REVERSE if item_index == active_index else 0
            if view == "pending":
                _path, request = item
                line = f"{item_index + 1:2d} {timestamp_label(request.get('created_at')):23s}  {summarize(request)}"
            elif view == "blacklist":
                kind, _rule_index, entry = item
                target = ssh_alias_target(entry) if kind == "ssh" else approval_target(entry)
                line = f"{item_index + 1:2d} {kind:7s}     {target:36s}  {entry.get('name') or entry.get('alias', '')}"
            elif view == "ssh":
                alias, entry = item
                line = f"{item_index + 1:2d} {alias:18s} {ssh_alias_target(entry):40s} {entry.get('identity_file', '')}"
            else:
                _rule_index, rule = item
                line = f"{item_index + 1:2d} {ttl_label(rule.get('expires_at')):10s}  {approval_target(rule):36s}  {rule.get('name', 'unnamed')}"
            draw_text(stdscr, 5 + row, 0, line, attr)
        if active_rows and show_detail:
            y = 6 + list_height
            if view == "pending":
                path, selected = active_rows[active_index]
                lines = detail_lines(selected, TTL_CHOICES[ttl_index], path)
            elif view == "blacklist":
                kind, _, selected = active_rows[active_index]
                lines = ssh_block_detail_lines(selected) if kind == "ssh" else block_detail_lines(selected)
            elif view == "ssh":
                alias, selected = active_rows[active_index]
                lines = ssh_alias_detail_lines(alias, selected)
            else:
                _, selected = active_rows[active_index]
                lines = approval_detail_lines(selected)
            draw_wrapped_lines(stdscr, y, width, lines[: max(0, height - y - 1)], height - 1)
        elif not active_rows:
            empty = {
                "pending": "No pending requests.",
                "approvals": "No active approvals.",
                "blacklist": "No blocklisted targets.",
                "ssh": "No SSH aliases.",
            }[view]
            draw_text(stdscr, 6, 0, empty)
        else:
            draw_text(stdscr, 6 + list_height, 0, "Details hidden. Press Enter to show them.")
        stdscr.refresh()

        key = stdscr.getch()
        if key == -1:
            message = ""
            continue
        message = ""
        if key in (ord("q"), 27):
            break
        if key in (ord("\t"),):
            view = VIEW_CHOICES[(VIEW_CHOICES.index(view) + 1) % len(VIEW_CHOICES)]
        elif key == ord("s"):
            sort_index = (sort_index + 1) % len(SORT_CHOICES)
        elif key in (curses.KEY_DOWN, ord("j")) and active_rows:
            if view == "pending":
                index = min(index + 1, len(requests) - 1)
            elif view == "approvals":
                approval_index = min(approval_index + 1, len(approvals) - 1)
            elif view == "blacklist":
                block_index = min(block_index + 1, len(blocks) - 1)
            else:
                ssh_index = min(ssh_index + 1, len(ssh_aliases) - 1)
        elif key in (curses.KEY_UP, ord("k")) and active_rows:
            if view == "pending":
                index = max(index - 1, 0)
            elif view == "approvals":
                approval_index = max(approval_index - 1, 0)
            elif view == "blacklist":
                block_index = max(block_index - 1, 0)
            else:
                ssh_index = max(ssh_index - 1, 0)
        elif key in (curses.KEY_NPAGE, ord(" ")) and active_rows:
            if view == "pending":
                index = move_page(index, len(requests), height, 1)
            elif view == "approvals":
                approval_index = move_page(approval_index, len(approvals), height, 1)
            elif view == "blacklist":
                block_index = move_page(block_index, len(blocks), height, 1)
            else:
                ssh_index = move_page(ssh_index, len(ssh_aliases), height, 1)
        elif key in (curses.KEY_PPAGE, ord("b"), ord("B")) and active_rows:
            if view == "pending":
                index = move_page(index, len(requests), height, -1)
            elif view == "approvals":
                approval_index = move_page(approval_index, len(approvals), height, -1)
            elif view == "blacklist":
                block_index = move_page(block_index, len(blocks), height, -1)
            else:
                ssh_index = move_page(ssh_index, len(ssh_aliases), height, -1)
        elif key in (ord("+"), ord("=")):
            ttl_index = min(ttl_index + 1, len(TTL_CHOICES) - 1)
        elif key in (ord("-"), ord("_")):
            ttl_index = max(ttl_index - 1, 0)
        elif key == ord("r") and view == "approvals" and approvals:
            rule_index, rule = approvals[approval_index]
            try:
                removed_rule = revoke_approval(rule_index)
                message = f"revoked {removed_rule.get('name') or approval_target(rule)}"
            except Exception as exc:
                message = f"revoke failed: {exc}"
        elif key == ord("r") and view == "blacklist" and blocks:
            kind, rule_index, rule = blocks[block_index]
            try:
                if kind == "ssh":
                    removed_rule = revoke_ssh_block(rule_index)
                    message = f"removed SSH block {removed_rule.get('alias', rule_index)}"
                else:
                    removed_rule = revoke_block(rule_index)
                    message = f"removed block {removed_rule.get('name') or approval_target(rule)}"
            except Exception as exc:
                message = f"block remove failed: {exc}"
        elif key == ord("r") and view == "ssh" and ssh_aliases:
            alias, _entry = ssh_aliases[ssh_index]
            try:
                remove_ssh_alias(alias)
                message = f"removed SSH alias {alias}"
            except Exception as exc:
                message = f"ssh alias remove failed: {exc}"
        elif key == ord("n") and view == "ssh":
            try:
                alias, _entry = add_ssh_alias(stdscr)
                message = f"added SSH alias {alias}"
            except Exception as exc:
                message = f"ssh alias add failed: {exc}"
        elif key == ord("a") and view == "pending" and requests:
            path, request = requests[index]
            try:
                approve_request(path, request, TTL_CHOICES[ttl_index], stdscr)
                message = f"approved {summarize(request)}"
            except Exception as exc:
                message = f"approve failed: {exc}"
        elif key == ord("d") and view == "pending" and requests:
            path, request = requests[index]
            reason = prompt_line(stdscr, "deny reason: ") or "denied by host operator"
            mark_request(path, request, "denied", reason)
            message = f"denied {summarize(request)}"
        elif key == ord("x") and view == "pending" and requests:
            path, request = requests[index]
            try:
                added = block_request(path, request)
                message = f"forever denied {len(added)} target(s)"
            except Exception as exc:
                message = f"forever deny failed: {exc}"
        elif key == ord("x") and view == "ssh" and ssh_aliases:
            alias, _entry = ssh_aliases[ssh_index]
            try:
                block_ssh_alias(alias)
                message = f"blocked SSH alias {alias}"
            except Exception as exc:
                message = f"ssh block failed: {exc}"
        elif key == ord("t") and view == "approvals" and approvals:
            rule_index, _rule = approvals[approval_index]
            ttl = TTL_CHOICES[ttl_index]
            try:
                updated_rule = set_approval_ttl(rule_index, ttl)
                message = f"set {updated_rule.get('name') or approval_target(updated_rule)} ttl to {ttl}"
            except Exception as exc:
                message = f"ttl update failed: {exc}"
        elif key in (curses.KEY_ENTER, 10, 13) and active_rows:
            show_detail = not show_detail


def main():
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        raise SystemExit("jail-operator requires an interactive terminal")
    POLICY_DIR.mkdir(parents=True, exist_ok=True)
    REQUEST_DIR.mkdir(parents=True, exist_ok=True)
    LEASE_DIR.mkdir(parents=True, exist_ok=True)
    curses.wrapper(app)


if __name__ == "__main__":
    main()
