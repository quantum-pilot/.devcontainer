#!/usr/bin/env bash
set -euo pipefail

devcontainer_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
config_file="$devcontainer_dir/devcontainer.json"
env_file="$devcontainer_dir/.env"

DEVCONTAINER_JSON="$config_file" DEVCONTAINER_ENV="$env_file" python3 - <<'PY'
import json
import os
from pathlib import Path

config_path = Path(os.environ["DEVCONTAINER_JSON"])
env_path = Path(os.environ["DEVCONTAINER_ENV"])

config = json.loads(config_path.read_text(encoding="utf-8"))
jail = config.get("customizations", {}).get("jail", {})
build_args = jail.get("buildArgs", {})

defaults = {
    "ENABLE_PYTHON": "false",
    "PYTHON_VERSION": "3.12",
    "ENABLE_GO": "false",
    "GO_VERSION": "1.26.4",
    "GO_ARCH": "amd64",
    "ENABLE_RUST": "false",
    "RUST_VERSION": "stable",
    "ENABLE_PLAYWRIGHT": "false",
}

def env_value(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    return str(value)

lines = [
    "# Generated by host/devcontainer-config from devcontainer.json.",
    "# Edit customizations.jail.buildArgs in devcontainer.json, not this file.",
]
for key, default in defaults.items():
    lines.append(f"{key}={env_value(build_args.get(key, default))}")

env_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
PY

printf 'wrote devcontainer compose env at %s\n' "$env_file"
