#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
import pathlib
import shlex
import sys
import uuid


POLICY_DIR = pathlib.Path(os.environ.get("JAIL_POLICY_DIR", pathlib.Path.home() / ".devcontainer-jail" / "policy"))
REQUEST_DIR = pathlib.Path(os.environ.get("JAIL_REQUEST_DIR", pathlib.Path.home() / ".devcontainer-jail" / "requests"))
ALLOWLIST = POLICY_DIR / "ssh-allowlist.json"
LEASE_DIR = POLICY_DIR / "ssh-leases"


def utc_now():
    return dt.datetime.now(dt.timezone.utc)


def parse_ttl(value):
    units = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    if value[-1] not in units:
        raise argparse.ArgumentTypeError("ttl must end in s, m, h, or d")
    return int(value[:-1]) * units[value[-1]]


def load_allowlist():
    if not ALLOWLIST.exists():
        raise SystemExit(f"missing allowlist: {ALLOWLIST}\nrun host/jail-init and add aliases first")
    data = json.loads(ALLOWLIST.read_text(encoding="utf-8"))
    return data.get("aliases", {})


def confirm(prompt):
    answer = input(f"{prompt} [y/N] ").strip().lower()
    return answer in {"y", "yes"}


def read_json(path):
    return json.loads(path.read_text(encoding="utf-8"))


def request_files(kind=None):
    files = []
    for path in REQUEST_DIR.glob("*.json"):
        try:
            request = read_json(path)
        except (OSError, json.JSONDecodeError):
            continue
        if kind and request.get("kind") != kind:
            continue
        files.append((path, request))
    return sorted(files, key=lambda item: item[0].name)


def broker_ssh(args):
    aliases = load_allowlist()
    if args.alias not in aliases:
        raise SystemExit(f"unknown SSH alias: {args.alias}")
    entry = aliases[args.alias]
    host = entry["host"]
    user = entry.get("user", os.environ.get("USER", ""))
    port = int(entry.get("port", 22))
    identity = entry.get("identity_file")
    command = args.command or entry.get("command", "")

    features = entry.get("features", {})
    if features.get("agent_forwarding") or features.get("x11_forwarding") or features.get("port_forwarding"):
        raise SystemExit("forwarding features are intentionally not supported by this broker")

    target = f"{user}@{host}" if user else host
    ssh_cmd = [
        "ssh",
        "-p", str(port),
        "-o", "ForwardAgent=no",
        "-o", "ForwardX11=no",
        "-o", "PermitLocalCommand=no",
        "-o", "ExitOnForwardFailure=yes",
        "-o", "ClearAllForwardings=yes",
    ]
    if identity:
        ssh_cmd.extend(["-i", os.path.expanduser(identity)])
    ssh_cmd.append(target)
    if command:
        ssh_cmd.append(command)

    print("SSH approval request")
    print(f"  alias: {args.alias}")
    print(f"  target: {target}")
    print(f"  port: {port}")
    print(f"  command: {command or '<interactive>'}")
    print(f"  exec: {shlex.join(ssh_cmd)}")
    if not args.yes and not confirm("open this host-side SSH session?"):
        raise SystemExit("denied")

    os.execvp(ssh_cmd[0], ssh_cmd)


def request_alias(request):
    payload = request.get("payload", {})
    return payload.get("alias")


def request_scope(request):
    payload = request.get("payload", {})
    return payload.get("scope") or payload.get("lease", {}).get("scope") or {}


def approve_lease(args):
    aliases = load_allowlist()
    request_path = pathlib.Path(args.request)
    if not request_path.is_absolute():
        request_path = REQUEST_DIR / request_path
    request = read_json(request_path)
    alias = request_alias(request)
    if not alias:
        raise SystemExit("request does not contain an SSH alias")
    if alias not in aliases:
        raise SystemExit(f"unknown SSH alias: {alias}")
    scope = request_scope(request)
    if not scope:
        raise SystemExit("request does not contain a process/session scope")

    ttl = args.ttl or request.get("payload", {}).get("ttl") or request.get("payload", {}).get("lease", {}).get("ttl") or "30m"
    expires = utc_now() + dt.timedelta(seconds=parse_ttl(ttl))
    lease_id = f"{utc_now().strftime('%Y%m%dT%H%M%SZ')}-{uuid.uuid4().hex[:12]}"
    lease = {
        "id": lease_id,
        "alias": alias,
        "created_at": utc_now().isoformat(),
        "expires_at": expires.isoformat(),
        "scope": {
            "sid": scope.get("sid"),
            "pgid": scope.get("pgid"),
            "uid": scope.get("uid"),
        },
        "request_id": request.get("id"),
        "request_file": str(request_path),
        "features": {
            "agent_forwarding": False,
            "x11_forwarding": False,
            "port_forwarding": False,
        },
    }

    print("SSH lease approval request")
    print(f"  alias: {alias}")
    print(f"  scope: sid={lease['scope']['sid']} pgid={lease['scope']['pgid']} uid={lease['scope']['uid']}")
    print(f"  expires: {lease['expires_at']}")
    if not args.yes and not confirm("approve this SSH lease?"):
        raise SystemExit("denied")

    LEASE_DIR.mkdir(parents=True, exist_ok=True)
    path = LEASE_DIR / f"{lease_id}.json"
    path.write_text(json.dumps(lease, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.chmod(path, 0o644)
    print(f"lease written: {path}")


def list_requests(args):
    for path, request in request_files(args.kind):
        payload = request.get("payload", {})
        alias = request_alias(request)
        print(f"{path.name}\tkind={request.get('kind')}\talias={alias or ''}\tcwd={request.get('cwd', '')}")


def list_leases(_args):
    for path in sorted(LEASE_DIR.glob("*.json")):
        try:
            lease = read_json(path)
        except (OSError, json.JSONDecodeError):
            continue
        scope = lease.get("scope", {})
        print(f"{path.name}\talias={lease.get('alias')}\texpires={lease.get('expires_at')}\tsid={scope.get('sid')}\tpgid={scope.get('pgid')}")


def prune_leases(_args):
    now = utc_now()
    removed = 0
    for path in sorted(LEASE_DIR.glob("*.json")):
        try:
            lease = read_json(path)
            expires_at = lease.get("expires_at")
            if expires_at and dt.datetime.fromisoformat(expires_at) <= now:
                path.unlink()
                removed += 1
        except (OSError, json.JSONDecodeError, ValueError):
            continue
    print(f"removed {removed} expired SSH lease(s)")


def list_aliases(_args):
    aliases = load_allowlist()
    for alias, entry in aliases.items():
        user = entry.get("user", "")
        host = entry.get("host", "")
        port = entry.get("port", 22)
        print(f"{alias}\t{user + '@' if user else ''}{host}:{port}")


def main():
    parser = argparse.ArgumentParser(description="Host-side SSH broker for hardened jail")
    sub = parser.add_subparsers(dest="command", required=True)

    run = sub.add_parser("ssh", help="open an approved SSH alias")
    run.add_argument("alias")
    run.add_argument("--command", default="")
    run.add_argument("-y", "--yes", action="store_true")
    run.set_defaults(func=broker_ssh)

    ls = sub.add_parser("list", help="list configured aliases")
    ls.set_defaults(func=list_aliases)

    reqs = sub.add_parser("requests", help="list worker SSH requests")
    reqs.add_argument("--kind", choices=["ssh", "ssh-lease"], default=None)
    reqs.set_defaults(func=list_requests)

    approve = sub.add_parser("approve-lease", help="approve a worker SSH lease request")
    approve.add_argument("request", help="request filename or absolute path")
    approve.add_argument("--ttl", default="")
    approve.add_argument("-y", "--yes", action="store_true")
    approve.set_defaults(func=approve_lease)

    leases = sub.add_parser("leases", help="list active SSH leases")
    leases.set_defaults(func=list_leases)

    prune = sub.add_parser("prune-leases", help="remove expired SSH leases")
    prune.set_defaults(func=prune_leases)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    sys.exit(main())
